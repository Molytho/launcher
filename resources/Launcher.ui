<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 1.0.2 -->
<interface>
  <!-- interface-name Launcher.ui -->
  <requires lib="gtk" version="4.10"/>
  <object class="GtkWindow" id="launcher">
    <property name="child">
      <object class="GtkBox" id="root-box">
        <property name="css-name">root-box</property>
        <property name="orientation">vertical</property>
        <property name="spacing">5</property>
        <child>
          <object class="GtkEntry" id="search">
            <property name="css-name">search</property>
            <property name="focusable">True</property>
            <property name="valign">center</property>
          </object>
        </child>
        <child>
          <object class="GtkScrolledWindow">
            <property name="focusable">True</property>
            <property name="hscrollbar-policy">never</property>
            <property name="vexpand">True</property>
            <child>
              <object class="GtkViewport">
                <child>
                  <object class="GtkListBox" id="app-list">
                    <property name="css-name">app-list</property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </property>
    <property name="css-name">launcher</property>
    <property name="decorated">False</property>
    <property name="default-height">600</property>
    <property name="default-width">1300</property>
    <property name="resizable">False</property>
  </object>
</interface>
