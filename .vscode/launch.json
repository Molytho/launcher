{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb-dap",
            "request": "launch",
            "name": "Launch launcher",
            "program": "${workspaceFolder}/build/launcher",
            "console": "integratedTerminal",
            "env": ["LAUNCHER_NO_PLATFORM_SETUP=1"],
            "cwd": "${workspaceFolder}/build/",
            "preLaunchTask": "Build"
        }
    ]
}